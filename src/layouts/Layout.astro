---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import ClockCursorEffect from '@/components/public/ClockCursorEffect.astro';
import SiteHeader from '@/components/public/SiteHeader.astro';
import SiteFooter from '@/components/public/SiteFooter.astro';
import { getSiteSettings } from '@/lib/content';

interface Props {
  title?: string;
  description?: string;
  hideChrome?: boolean;
}

const { title, description, hideChrome = false } = Astro.props;
const settings = await getSiteSettings();
const pageTitle = title ? `${title} · ${settings.team_name}` : settings.team_name;
const pageDescription = description ?? settings.tagline;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Silkscreen:wght@400;700&display=swap"
    />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-dvh flex flex-col">
    <div class="ascii-page-bg" data-ascii-donut aria-label="Rotating ASCII donut background">
      <div class="quiet-data-decor" data-quiet-decor aria-hidden="true">
        <div class="quiet-data-rail">
          <span>0x9F3A</span>
          <span>sector_04</span>
          <span>latency 12ms</span>
          <span>uplink stable</span>
          <span>node:a3</span>
          <span>0x9F3A</span>
        </div>
        <div class="packet-trail packet-trail--top"></div>
        <div class="packet-trail packet-trail--mid"></div>
        <div class="packet-trail packet-trail--low"></div>
        <div class="quiet-hud-label quiet-hud-label--left">node:a3</div>
        <div class="quiet-hud-label quiet-hud-label--top">latency:12ms</div>
        <div class="quiet-hud-label quiet-hud-label--bottom">sector_04 / uplink stable</div>
        <div class="ascii-orb ascii-moon" data-ascii-moon>
          <div class="ascii-orb__label">moon.sys</div>
          <pre class="ascii-moon__frame" data-ascii-moon-frame aria-hidden="true">      _..._      
   .-'   .''.    
  /   .-'    \   
 |   /  .--.  |  
 |   | (    ) |  
 |   \  '--' /   
  \   '-.__.'    
   '-._____.-'   </pre>
        </div>
        <div class="ascii-orb ascii-earth" data-ascii-earth>
          <div class="ascii-orb__label">earth.sys</div>
          <pre class="ascii-earth__frame" data-ascii-earth-frame aria-hidden="true">          _..---.._         
      .-''  .- .-.  ''-.     
    .'     /  /   \     '.   
   /      |  |  _  |      \  
  ;   .--.|  | (_) |.--.   ; 
  |  /    \\  \\_/ //    \\  | 
  |  |  .-''-.___.-''-.  |  | 
  ;  | /   .--. .--.   \\ |  ; 
   \\ | |  /    Y    \\  | | /  
    '.\\ \\ \\__/\\_/\\__/ / /.'   
      '-._'-..____..-'_.-'    
           ''------''         </pre>
          <div class="ascii-earth__vn" data-vn-marker>VN</div>
        </div>
      </div>
      <div class="ascii-page-bg__shell">
        <div class="ascii-page-bg__bar">
          <span class="led on-magenta"></span>
          <span>torus.exe</span>
        </div>
        <pre class="ascii-page-bg__frame" data-ascii-donut-frame aria-hidden="true">          ******          
       **########**       
     **############**     
    *#####******#####*    
   *####**      **####*   
  *####*          *####*  
  *####*          *####*  
   *####**      **####*   
    *#####******#####*    
     **############**     
       **########**       
          ******          </pre>
      </div>
    </div>
    {!hideChrome && <SiteHeader settings={settings} />}
    <main class="flex-1 site-main">
      <slot />
    </main>
    {!hideChrome && <SiteFooter settings={settings} />}
    <ClockCursorEffect />
    <script is:inline>
      (() => {
        const width = 42;
        const height = 22;
        const luminance = '.,-~:;=!*#$@';

        function renderAsciiDonut(frame = 0) {
          const output = Array(width * height).fill(' ');
          const depth = Array(width * height).fill(0);
          const a = frame * 0.055;
          const b = frame * 0.032;
          const sinA = Math.sin(a);
          const cosA = Math.cos(a);
          const sinB = Math.sin(b);
          const cosB = Math.cos(b);

          for (let theta = 0; theta < Math.PI * 2; theta += 0.17) {
            const sinTheta = Math.sin(theta);
            const cosTheta = Math.cos(theta);

            for (let phi = 0; phi < Math.PI * 2; phi += 0.08) {
              const sinPhi = Math.sin(phi);
              const cosPhi = Math.cos(phi);
              const ring = 2 + cosTheta;
              const inverseZ = 1 / (sinPhi * ring * sinA + sinTheta * cosA + 5);
              const x = Math.floor(width / 2 + width * 0.38 * inverseZ * (cosPhi * ring * cosB - (sinPhi * ring * cosA - sinTheta * sinA) * sinB));
              const y = Math.floor(height / 2 + height * 0.8 * inverseZ * (cosPhi * ring * sinB + (sinPhi * ring * cosA - sinTheta * sinA) * cosB));
              const index = x + width * y;
              const shade = Math.floor(8 * ((sinTheta * sinA - sinPhi * cosTheta * cosA) * cosB - sinPhi * cosTheta * sinA - sinTheta * cosA - cosPhi * cosTheta * sinB));

              if (y >= 0 && y < height && x >= 0 && x < width && inverseZ > depth[index]) {
                depth[index] = inverseZ;
                output[index] = luminance[Math.max(0, Math.min(luminance.length - 1, shade))];
              }
            }
          }

          return output.reduce((rows, char, index) => {
            rows += char;
            return (index + 1) % width === 0 ? `${rows}\n` : rows;
          }, '');
        }

        function renderAsciiEarth(frame = 0) {
          const earthWidth = 29;
          const earthHeight = 12;
          const output = [];
          const phase = frame * 0.018;
          const palette = ' .,:;=+*#@';

          for (let y = 0; y < earthHeight; y += 1) {
            let row = '';
            const ny = (y / (earthHeight - 1)) * 2 - 1;
            const curve = 1 - ny * ny;
            const radius = Math.sqrt(Math.max(0, curve));

            for (let x = 0; x < earthWidth; x += 1) {
              const nx = (x / (earthWidth - 1)) * 2 - 1;
              if (Math.abs(nx) > radius * 1.1) {
                row += ' ';
                continue;
              }

              const sphereX = nx / Math.max(radius, 0.001);
              const coast =
                0.52 * Math.sin(sphereX * 2.8 + phase) +
                0.28 * Math.cos(ny * 4.6 - phase * 1.4) +
                0.18 * Math.sin((sphereX + ny) * 6.2 + phase * 0.5);
              const cloud =
                0.3 * Math.sin(sphereX * 9 - phase * 1.2) +
                0.18 * Math.cos(ny * 8 + phase * 1.7);
              const light = 0.45 + 0.55 * (sphereX * 0.7 + radius * 0.45);
              const shade = Math.max(0, Math.min(1, light + cloud * 0.14));
              const tone = palette[Math.max(0, Math.min(palette.length - 1, Math.floor(shade * (palette.length - 1))))];

              if (Math.abs(Math.abs(nx) - radius) < 0.09) {
                row += '.';
              } else if (coast > 0.2) {
                row += tone === ' ' ? '.' : tone;
              } else {
                row += cloud > 0.3 ? ':' : ' ';
              }
            }

            output.push(row);
          }

          return output.join('\n');
        }

        function renderAsciiMoon(frame = 0) {
          const moonWidth = 18;
          const moonHeight = 10;
          const output = [];
          const phase = frame * 0.013;
          const palette = ' .:-=+*#%@';

          for (let y = 0; y < moonHeight; y += 1) {
            let row = '';
            const ny = (y / (moonHeight - 1)) * 2 - 1;
            const curve = 1 - ny * ny;
            const radius = Math.sqrt(Math.max(0, curve));

            for (let x = 0; x < moonWidth; x += 1) {
              const nx = (x / (moonWidth - 1)) * 2 - 1;
              if (Math.abs(nx) > radius * 1.06) {
                row += ' ';
                continue;
              }

              const sphereX = nx / Math.max(radius, 0.001);
              const light = 0.52 + 0.48 * (sphereX * 0.9 - 0.18);
              const crater =
                0.22 * Math.sin(sphereX * 8 + phase) +
                0.18 * Math.cos(ny * 7 - phase * 1.3) +
                0.08 * Math.sin((sphereX - ny) * 14);
              const shade = Math.max(0, Math.min(1, light - crater));
              const tone = palette[Math.max(0, Math.min(palette.length - 1, Math.floor(shade * (palette.length - 1))))];

              if (Math.abs(Math.abs(nx) - radius) < 0.08) {
                row += '.';
              } else if (crater > 0.14) {
                row += ':';
              } else {
                row += tone;
              }
            }

            output.push(row);
          }

          return output.join('\n');
        }

        function mountAsciiDonutBackground() {
          const existing = window.__asciiDonutBackground;
          if (existing?.donut?.isConnected) return;
          if (existing?.destroy) existing.destroy();

          const donut = document.querySelector('[data-ascii-donut-frame]');
          const earth = document.querySelector('[data-ascii-earth-frame]');
          const moon = document.querySelector('[data-ascii-moon-frame]');
          const media = window.matchMedia('(prefers-reduced-motion: reduce)');
          let animationFrame = 0;

          if (!(donut instanceof HTMLElement)) return;

          function renderAtTime(now) {
            const frame = now * 0.024;
            donut.textContent = renderAsciiDonut(frame);
            if (earth instanceof HTMLElement) earth.textContent = renderAsciiEarth(frame);
            if (moon instanceof HTMLElement) moon.textContent = renderAsciiMoon(frame);
          }

          function stop() {
            window.cancelAnimationFrame(animationFrame);
            animationFrame = 0;
          }

          function destroy() {
            stop();
            document.removeEventListener('visibilitychange', handleVisibilityChange);
            media.removeEventListener('change', handleMotionChange);
            window.__asciiDonutBackground = null;
          }

          function tick(now) {
            if (!donut.isConnected) {
              destroy();
              return;
            }
            renderAtTime(now);
            animationFrame = window.requestAnimationFrame(tick);
          }

          function start() {
            if (animationFrame || media.matches) return;
            animationFrame = window.requestAnimationFrame(tick);
          }

          function handleVisibilityChange() {
            if (document.visibilityState === 'visible') {
              renderAtTime(performance.now());
              start();
            } else {
              stop();
            }
          }

          function handleMotionChange(event) {
            if (event.matches) {
              stop();
              return;
            }
            renderAtTime(performance.now());
            start();
          }

          renderAtTime(performance.now());
          document.addEventListener('visibilitychange', handleVisibilityChange);
          media.addEventListener('change', handleMotionChange);
          start();

          window.__asciiDonutBackground = { destroy, donut, earth, moon };
        }

        window.__mountAsciiDonutBackground = mountAsciiDonutBackground;
        mountAsciiDonutBackground();

        if (!window.__asciiDonutBackgroundListenerStarted) {
          window.__asciiDonutBackgroundListenerStarted = true;
          document.addEventListener('astro:page-load', () => {
            window.__mountAsciiDonutBackground?.();
          });
        }
      })();
    </script>
    <script is:inline>
      (() => {
        if (window.__pressFeedbackStarted) return;
        window.__pressFeedbackStarted = true;

        const selector = 'a[href], button, summary, [role="button"], input, textarea, select, .px-frame, .px-btn, .chip';
        let active = null;
        let timer = 0;

        function release() {
          if (!active) return;
          active.classList.remove('is-pressing');
          active = null;
        }

        document.addEventListener('pointerdown', (event) => {
          if (!(event.target instanceof Element)) return;
          const target = event.target.closest(selector);
          if (!(target instanceof HTMLElement)) return;

          const rect = target.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / Math.max(rect.width, 1)) * 100;
          const y = ((event.clientY - rect.top) / Math.max(rect.height, 1)) * 100;

          window.clearTimeout(timer);
          release();
          active = target;
          active.classList.add('pressable', 'is-pressing');
          active.style.setProperty('--press-x', x.toFixed(2) + '%');
          active.style.setProperty('--press-y', y.toFixed(2) + '%');
          timer = window.setTimeout(release, 190);
        }, { passive: true });

        document.addEventListener('pointerup', () => {
          window.clearTimeout(timer);
          timer = window.setTimeout(release, 90);
        }, { passive: true });

        document.addEventListener('pointercancel', release, { passive: true });
        document.addEventListener('keydown', (event) => {
          if (event.key !== 'Enter' && event.key !== ' ') return;
          if (!(event.target instanceof HTMLElement)) return;
          const target = event.target.closest(selector);
          if (!(target instanceof HTMLElement)) return;
          target.classList.add('pressable', 'is-pressing');
          window.setTimeout(() => target.classList.remove('is-pressing'), 150);
        });
      })();
    </script>
  </body>
</html>
