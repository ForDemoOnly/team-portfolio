---
import Layout from '@/layouts/Layout.astro';
import { getProjects, getSiteSettings, getTeamMembers } from '@/lib/content';
import { binColumn, fakeBytes, fakePing, hexId, tcpFlag } from '@/lib/fx';

const settings = await getSiteSettings();
const featured = await getProjects({ featuredOnly: true });
const team = await getTeamMembers();
const handle = settings.team_name.toLowerCase().replace(/\s+/g, '_');
const bin = binColumn(settings.team_name);
---

<Layout>
  <!-- ========== HERO ========== -->
  <section class="mx-auto max-w-6xl px-6 pt-10 pb-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-6">

      <!-- Left: boot log + pixel name -->
      <div class="px-frame is-cyan">
        <div class="px-inner p-6 md:p-8">
          <div class="flex items-center justify-between text-[11px] font-pixel text-[var(--muted)]">
            <div class="flex items-center gap-2">
              <span class="led on-green"></span>
              <span>boot.log</span>
            </div>
            <div>pid:0x{hexId(settings.team_name, 4)} · ttl:∞</div>
          </div>

          <div class="boot-log mt-5 text-[13px] leading-6 text-[var(--fg)]/90">
            <div><span class="text-[var(--muted)]">[  0.000]</span> BOOT /dev/team <span class="text-[var(--green)]">OK</span></div>
            <div><span class="text-[var(--muted)]">[  0.021]</span> net: carrier detected on eth0 (1000BASE-T)</div>
            <div><span class="text-[var(--muted)]">[  0.054]</span> auth: loaded <span class="text-[var(--amber)]">{team.length}</span> keypairs</div>
            <div><span class="text-[var(--muted)]">[  0.112]</span> ai: embedding cache warm <span class="text-[var(--cyan)]">1.2GB</span></div>
            <div><span class="text-[var(--muted)]">[  0.203]</span> router: linking to public internet</div>
            <div><span class="text-[var(--muted)]">[  0.310]</span> <span class="text-[var(--green)]">READY</span>. awaiting input_<span class="cursor"></span></div>
          </div>

          <hr class="hr-dashed my-6" />

          <p class="font-pixel text-[11px] tracking-wider text-[var(--muted)]">&gt;&gt; HELLO, VISITOR — WE ARE</p>
          <h1 class="h-pixel text-[clamp(28px,6vw,64px)] mt-3 text-[var(--cyan)] glow-cyan">
            {settings.team_name}
          </h1>
          <p class="mt-5 text-[15px] md:text-lg leading-7 max-w-2xl">
            {settings.tagline}
          </p>

          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/projects" class="px-btn is-primary">[ ./projects ]</a>
            <a href="/team" class="px-btn">[ ./team ]</a>
            <a href="/contact" class="px-btn">[ ./contact ]</a>
          </div>
        </div>
      </div>

      <!-- Right: network/system panel + binary rain -->
      <div class="flex flex-col gap-4">
        <div class="px-frame is-magenta">
          <div class="px-inner p-5 text-[12px]">
            <p class="font-pixel text-[10px] tracking-wider text-[var(--magenta)]">NET_TOPOLOGY.CFG</p>
            <pre class="mt-3 text-[11px] leading-[1.45] text-[var(--fg)]/85">{`
        ┌──[gateway]──┐
        │  ping 1ms   │
        └──────┬──────┘
               │
    ┌──────────┼──────────┐
    ▼          ▼          ▼
 [node-01]  [node-02]  [node-03]
  ONLINE     ONLINE     ONLINE
   ${String(fakePing(team[0]?.id ?? 'a')).padStart(5)}     ${String(fakePing(team[1]?.id ?? 'b')).padStart(5)}     ${String(fakePing(team[2]?.id ?? 'c')).padStart(5)}
`}</pre>
            <div class="mt-3 flex items-center justify-between text-[10px] font-pixel tracking-wider text-[var(--muted)]">
              <span>nodes:{String(team.length).padStart(2, '0')}</span>
              <span class="text-[var(--green)]">● ok</span>
            </div>
          </div>
        </div>

        <div class="px-frame">
          <div class="px-inner p-5">
            <p class="font-pixel text-[10px] tracking-wider text-[var(--muted)]">RAW_STREAM.BIN</p>
            <pre class="binary-rain mt-2">{bin}</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURED PACKETS ========== -->
  {featured.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-8">
      <div class="flex items-end justify-between mb-4">
        <div>
          <p class="font-pixel text-[10px] tracking-wider text-[var(--muted)]">SNIFFER › FEATURED</p>
          <h2 class="h-pixel text-2xl mt-2 text-[var(--fg)]">inbound_packets</h2>
        </div>
        <a href="/projects" class="link-accent text-[12px]">see all →</a>
      </div>

      <div class="px-frame">
        <div class="px-inner">
          <div class="grid grid-cols-[3ch_auto_1fr_auto_auto_auto] gap-4 px-4 py-2 text-[10px] font-pixel tracking-wider text-[var(--muted)] border-b border-[var(--line-2)]">
            <span>#</span><span>flg</span><span>host</span><span>bytes</span><span>rtt</span><span>state</span>
          </div>
          {featured.map((p, i) => (
            <a href={`/projects/${p.slug}`} class="packet-row hover:text-[var(--cyan)]">
              <span class="text-[var(--muted)] tabular-nums">{String(i).padStart(2, '0')}</span>
              <span class={`flag is-${['cyan','magenta','amber','green'][i%4]}`}>{tcpFlag(i)}</span>
              <span class="truncate">
                <span class="text-[var(--cyan)]">{p.title}</span>
                <span class="text-[var(--muted)]"> → :443  <span class="hidden sm:inline">· {p.summary}</span></span>
              </span>
              <span class="text-[var(--amber)] tabular-nums">{fakeBytes(p.slug)}</span>
              <span class="text-[var(--violet)] tabular-nums">{fakePing(p.slug)}</span>
              <span class="tag is-green">OK</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== TEAM PREVIEW ========== -->
  <section class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex items-end justify-between mb-4">
      <div>
        <p class="font-pixel text-[10px] tracking-wider text-[var(--muted)]">REGISTRY › USERS</p>
        <h2 class="h-pixel text-2xl mt-2">./whois {handle}</h2>
      </div>
      <a href="/team" class="link-accent text-[12px]">view registry →</a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {team.slice(0, 6).map((m, i) => (
        <div class={`px-frame ${i % 3 === 0 ? 'is-cyan' : i % 3 === 1 ? 'is-magenta' : 'is-amber'}`}>
          <div class="px-inner p-4">
            <div class="flex items-center justify-between text-[10px] font-pixel tracking-wider">
              <span class="text-[var(--muted)]">ID·0x{hexId(m.id, 4)}</span>
              <span class="text-[var(--green)] flex items-center gap-1"><span class="led on-green"></span>ONLINE</span>
            </div>
            <div class="mt-3 font-pixel text-[13px] truncate">{m.name}</div>
            <div class="text-[11px] text-[var(--muted)] mt-1 uppercase tracking-wider truncate">CLASS · {m.role}</div>
            <div class="mt-3 flex items-center gap-2 text-[10px] font-pixel">
              <span class="text-[var(--muted)]">HP</span>
              <span class="text-[var(--green)] tracking-tight">██████████</span>
              <span class="text-[var(--muted)]">100</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
