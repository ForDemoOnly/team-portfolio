---
import Layout from '@/layouts/Layout.astro';
import { getProjects, getSiteSettings, getTeamMembers } from '@/lib/content';
import { hexId } from '@/lib/fx';

const settings = await getSiteSettings();
const allProjects = await getProjects();
const featured = allProjects.filter((p) => p.featured);
const team = await getTeamMembers();
const handle = settings.team_name.toLowerCase().replace(/\s+/g, '_');
const buildDate = new Date().toISOString().slice(0, 10);
---

<Layout>
  <!-- ========== HERO ========== -->
  <section class="mx-auto max-w-6xl px-6 pt-10 pb-16">
    <div>
      <!-- Boot log + pixel name -->
      <div class="px-frame is-cyan">
        <div class="px-inner p-6 md:p-8">
          <div class="flex items-center justify-between text-[11px] font-pixel text-[var(--muted)]">
            <div class="flex items-center gap-2">
              <span class="led on-green"></span>
              <span>boot.log</span>
            </div>
            <div>built {buildDate}</div>
          </div>

          <div class="boot-log mt-5 text-[13px] leading-6 text-[var(--fg)]/90">
            <div><span class="text-[var(--muted)]">[mount]</span> /dev/team <span class="text-[var(--green)]">OK</span></div>
            <div><span class="text-[var(--muted)]">[load ]</span> team members: <span class="text-[var(--amber)]">{team.length}</span></div>
            <div><span class="text-[var(--muted)]">[load ]</span> projects: <span class="text-[var(--amber)]">{allProjects.length}</span> <span class="text-[var(--muted)]">({featured.length} featured)</span></div>
            <div><span class="text-[var(--muted)]">[route]</span> / · ./about · ./team · ./projects · ./contact</div>
            <div><span class="text-[var(--muted)]">[ok   ]</span> <span class="text-[var(--green)]">READY</span>. awaiting input_<span class="cursor"></span></div>
          </div>

          <hr class="hr-dashed my-6" />

          <div>
            <p class="font-pixel text-[11px] tracking-wider text-[var(--muted)]">&gt;&gt; HELLO, VISITOR — WE ARE</p>
            <h1 class="h-pixel text-[clamp(28px,6vw,64px)] mt-3 text-[var(--cyan)] glow-cyan">
              {settings.team_name}
            </h1>
            <p class="mt-5 text-[15px] md:text-lg leading-7 max-w-2xl">
              {settings.tagline}
            </p>

            <div class="mt-7 flex flex-wrap gap-3">
              <a href="/projects" class="px-btn is-primary">[ ./projects ]</a>
              <a href="/team" class="px-btn">[ ./team ]</a>
              <a href="/contact" class="px-btn">[ ./contact ]</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURED PROJECTS ========== -->
  {featured.length > 0 && (
    <section class="mx-auto max-w-6xl px-6 py-8">
      <div class="flex items-end justify-between mb-4">
        <div>
          <p class="font-pixel text-[10px] tracking-wider text-[var(--muted)]">./projects · featured</p>
          <h2 class="h-pixel text-2xl mt-2 text-[var(--fg)]">featured</h2>
        </div>
        <a href="/projects" class="link-accent text-[12px]">see all →</a>
      </div>

      <div class="px-frame">
        <div class="px-inner">
          <div class="grid grid-cols-[3ch_1fr_auto] gap-2 sm:gap-4 px-4 py-2 text-[10px] font-pixel tracking-wider text-[var(--muted)] border-b border-[var(--line-2)]">
            <span>#</span>
            <span>title · summary</span>
            <span class="hidden sm:inline">tech</span>
          </div>
          {featured.map((p, i) => (
            <a href={`/projects/${p.slug}`} class="packet-row hover:text-[var(--cyan)]">
              <span class="text-[var(--muted)] tabular-nums">{String(i + 1).padStart(2, '0')}</span>
              <span class="truncate">
                <span class="text-[var(--cyan)]">{p.title}</span>
                <span class="text-[var(--muted)]"> · {p.summary}</span>
              </span>
              <span class="hidden sm:inline text-[var(--muted)] text-[11px] tabular-nums whitespace-nowrap">
                {p.tech_stack.length > 0 ? p.tech_stack.slice(0, 2).join(' · ') : '—'}
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ========== TEAM PREVIEW ========== -->
  <section class="mx-auto max-w-6xl px-6 py-10">
    <div class="flex items-end justify-between mb-4">
      <div>
        <p class="font-pixel text-[10px] tracking-wider text-[var(--muted)]">REGISTRY › USERS</p>
        <h2 class="h-pixel text-2xl mt-2">./whois {handle}</h2>
      </div>
      <a href="/team" class="link-accent text-[12px]">view registry →</a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {team.slice(0, 6).map((m, i) => {
        const socials = Object.entries(m.socials ?? {}).filter(([, v]) => Boolean(v));
        return (
          <a href="/team" class={`px-frame ${i % 3 === 0 ? 'is-cyan' : i % 3 === 1 ? 'is-magenta' : 'is-amber'} block hover:brightness-110 transition`}>
            <div class="px-inner p-4">
              <div class="flex items-center justify-between text-[10px] font-pixel tracking-wider">
                <span class="text-[var(--muted)]">id·0x{hexId(m.id, 4)}</span>
                <span class="text-[var(--muted)]">{socials.length} {socials.length === 1 ? 'link' : 'links'}</span>
              </div>
              <div class="mt-3 font-pixel text-[13px] truncate">{m.name}</div>
              <div class="text-[11px] text-[var(--muted)] mt-1 uppercase tracking-wider truncate">{m.role}</div>
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
