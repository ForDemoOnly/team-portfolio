---
import Layout from '@/layouts/Layout.astro';
import { getProjects } from '@/lib/content';

const projects = await getProjects();
const featuredCount = projects.filter((p) => p.featured).length;
---

<Layout title="Projects">
  <section class="mx-auto max-w-6xl px-6 pt-12 pb-24">
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <div>
        <p class="font-pixel text-[11px] tracking-wider text-[var(--muted)]">./projects</p>
        <h1 class="h-pixel text-[clamp(28px,5vw,48px)] mt-3 text-[var(--amber)] glow-amber">projects</h1>
      </div>
      <div class="text-[11px] font-pixel tracking-wider text-[var(--muted)] text-right">
        <div><span class="text-[var(--green)]">{String(projects.length).padStart(3, '0')}</span> total</div>
        <div><span class="text-[var(--magenta)]">{String(featuredCount).padStart(3, '0')}</span> featured</div>
      </div>
    </div>

    <!-- projects table -->
    <div class="mt-8 px-frame is-amber">
      <div class="px-inner">
        <div class="grid grid-cols-[3ch_1fr_auto] gap-2 sm:gap-4 px-4 py-2 text-[10px] font-pixel tracking-wider text-[var(--muted)] border-b border-[var(--line-2)]">
          <span>#</span>
          <span>title<span class="hidden sm:inline"> · summary</span></span>
          <span>state</span>
        </div>
        {projects.map((p, i) => (
          <a href={`/projects/${p.slug}`} class="packet-row hover:text-[var(--cyan)]">
            <span class="text-[var(--muted)] tabular-nums">{String(i + 1).padStart(2, '0')}</span>
            <span class="truncate">
              <span class="text-[var(--cyan)]">{p.title}</span>
              <span class="text-[var(--muted)] hidden sm:inline"> · {p.summary}</span>
            </span>
            <span class={`tag ${p.featured ? 'is-magenta' : 'is-green'}`}>{p.featured ? 'FEAT' : 'OK'}</span>
          </a>
        ))}
        {projects.length === 0 && (
          <div class="p-8 text-center text-[var(--muted)] font-pixel tracking-widest">[ no projects yet ]</div>
        )}
      </div>
    </div>
  </section>
</Layout>
