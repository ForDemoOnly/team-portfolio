---
import Layout from '@/layouts/Layout.astro';
import { getSiteSettings, getTeamMembers, getProjects } from '@/lib/content';

const settings = await getSiteSettings();
const team = await getTeamMembers();
const projects = await getProjects();
const featured = projects.filter((p) => p.featured).length;
const contact = settings.contact_email;
const roles = Array.from(new Set(team.map((m) => m.role))).sort();
---

<Layout title="About">
  <section class="mx-auto max-w-4xl px-6 pt-12 pb-24">
    <p class="font-pixel text-[11px] tracking-wider text-[var(--muted)]">./about</p>
    <h1 class="h-pixel text-[clamp(28px,5vw,48px)] mt-3 text-[var(--cyan)] glow-cyan">about</h1>

    <!-- summary block -->
    <div class="mt-8 px-frame is-amber">
      <div class="px-inner p-5 md:p-6 text-[13px] leading-7">
        <div class="grid sm:grid-cols-[10ch_1fr] gap-x-4">
          <span class="text-[var(--muted)]">team</span><span class="text-[var(--amber)]">{settings.team_name}</span>
          <span class="text-[var(--muted)]">members</span><span>{team.length}</span>
          <span class="text-[var(--muted)]">roles</span><span>{roles.length > 0 ? roles.join(' · ') : '—'}</span>
          <span class="text-[var(--muted)]">projects</span><span>{projects.length} <span class="text-[var(--muted)]">({featured} featured)</span></span>
          {contact && (<><span class="text-[var(--muted)]">contact</span><a href={`mailto:${contact}`} class="link-accent break-all">{contact}</a></>)}
        </div>
      </div>
    </div>

    <!-- Mission -->
    <div class="mt-8">
      <p class="prompt-arrow font-pixel text-[11px] tracking-wider text-[var(--green)]">./mission</p>
      <h2 class="text-2xl md:text-4xl leading-[1.2] mt-3">{settings.tagline}</h2>
    </div>

    {settings.about && (
      <div class="mt-8 text-[15px] leading-7 text-[var(--fg)]/90 whitespace-pre-line">
        {settings.about}
      </div>
    )}
  </section>
</Layout>
