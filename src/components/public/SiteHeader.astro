---
import type { SiteSettings } from '@/lib/types';
interface Props { settings: SiteSettings }
const { settings } = Astro.props;
const nav = [
  { href: '/', label: 'home' },
  { href: '/about', label: 'about' },
  { href: '/team', label: 'team' },
  { href: '/projects', label: 'projects' },
  { href: '/contact', label: 'contact' },
];
const pathname = Astro.url.pathname;
const slug = settings.team_name.toLowerCase().replace(/\s+/g, '-');
---

<header class="sticky top-0 z-30 border-b border-[var(--line-2)] bg-[rgba(5,6,10,0.82)] backdrop-blur">
  <div class="mx-auto max-w-6xl px-6 h-12 flex items-center justify-between text-[12px]">
    <a href="/" class="flex items-center gap-3 group">
      <span class="led on-cyan"></span>
      <span class="font-pixel text-[13px] tracking-wider group-hover:text-[var(--cyan)] transition-colors">{slug}.net</span>
      <span class="hidden sm:inline text-[var(--muted)]">· 0x{Math.abs(slug.split('').reduce((a,c)=>a+c.charCodeAt(0),0)).toString(16).toUpperCase().padStart(4,'0').slice(-4)}</span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      {nav.map((item) => {
        const active = item.href === '/' ? pathname === '/' : pathname.startsWith(item.href);
        return (
          <a
            href={item.href}
            class:list={[
              'px-3 py-1 font-pixel text-[11px] tracking-wider transition-colors',
              active
                ? 'text-[var(--cyan)]'
                : 'text-[var(--muted)] hover:text-[var(--fg)]',
            ]}
          >
            [{active ? '●' : ' '}] {item.label}
          </a>
        );
      })}
    </nav>

    <div class="hidden md:flex items-center gap-2 text-[var(--muted)]">
      <span class="font-pixel text-[10px]">SIG</span>
      <span class="tracking-tight text-[var(--green)]">▁▂▄▆█</span>
      <span class="font-pixel text-[10px]">ONLINE</span>
    </div>
  </div>
</header>
